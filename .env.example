# ============================================
# Web News Collector - 环境变量配置
# ============================================

# ---------- 基础配置 ----------
APP_NAME=web-news-collector
APP_ENV=development
DEBUG=true

# ---------- 后端服务 ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# ---------- 数据库 ----------
# 开发环境使用 SQLite，生产环境建议 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/news.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/news_collector

# ---------- Redis（缓存 & 任务队列） ----------
REDIS_URL=redis://localhost:6379/0

# ---------- 前端 ----------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------- AI / LLM 配置 ----------
# OpenAI 兼容接口（支持 OpenAI / DeepSeek / 本地 Ollama 等）
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---------- 爬虫配置 ----------
# 默认抓取间隔（秒）
CRAWL_INTERVAL=600
# 缓存 TTL（秒）
CACHE_TTL=1800
# 最大并发爬虫数
MAX_CONCURRENT_CRAWLERS=10
# 请求超时（秒）
REQUEST_TIMEOUT=15

# ---------- GitHub OAuth（可选，用户登录） ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/auth/callback

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_DIR=./logs
